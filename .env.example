# Elasticsearch Configuration
ELASTICSEARCH_HOSTS=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_VERIFY_CERTS=true
ELASTICSEARCH_CA_CERTS=

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Milvus Configuration
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_URI=./milvus_demo.db

# Embedding Model Selection
# Options: "simple" (fast, 5-dim), "transformer" (DistilBERT)
EMBEDDING_MODEL=simple

# SVO Extractor Selection
# Options: "mock" (hardcoded rules), "transformer" (Flan-T5)
SVO_EXTRACTOR=mock

# Backend Fallback Strategy
# If true, use real backends when available, fall back to SQLite
# If false, always use SQLite (for testing/CI)
USE_PRODUCTION_BACKENDS=true

# SQLite Database
SQLITE_DB_PATH=data/svo_data.db

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Ingestion
CHUNK_SIZE=512
EMBEDDING_DIM=768
